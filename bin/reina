#!/usr/bin/env zsh

setopt NO_UNSET PIPE_FAIL EXTENDED_GLOB NULL_GLOB

typeset -gx REINA_PROJECT_ROOT="${0:A:h:h}"

source "$REINA_PROJECT_ROOT/lib/services/errors.zsh"
source "$REINA_PROJECT_ROOT/lib/services/storage.zsh"
source "$REINA_PROJECT_ROOT/lib/services/network.zsh"
source "$REINA_PROJECT_ROOT/lib/core/json.zsh"
source "$REINA_PROJECT_ROOT/lib/core/logging.zsh"
source "$REINA_PROJECT_ROOT/lib/core/flags.zsh"
source "$REINA_PROJECT_ROOT/lib/core/bootstrap.zsh"
source "$REINA_PROJECT_ROOT/lib/core/manifest.zsh"
source "$REINA_PROJECT_ROOT/lib/core/context.zsh"
source "$REINA_PROJECT_ROOT/lib/core/operations.zsh"
source "$REINA_PROJECT_ROOT/lib/presets/dispatcher.zsh"

function reina_cmd_help() {
  cat <<EOF
Reina de Copas

Uso:
  reina help
  reina version
  reina list
  reina info <preset>
  reina graph <preset>
  reina run <preset>
  reina doctor
  reina history <preset>
  reina snapshot <preset> list|restore [key]
  reina prune [--cache|--all]
  reina net-check [url]
  reina <preset>

Comandos:
  help    muestra esta ayuda
  version muestra la version instalada
  list    lista los presets registrados en presets/manifest.tsv
  info    muestra metadata de un preset resolviendo slug, alias o nombre
  graph   muestra el grafo de red del preset: familia, hermanos, perfil remoto
  run     ejecuta el flujo base de un preset
  doctor  revisa runtime, dependencias, permisos y manifiesto
  history muestra el historial de ejecuciones de un preset
  snapshot lista o restaura snapshots de un preset
  prune   limpia cache vencida; --all incluye tmp y locks obsoletos
  net-check valida reachability de un endpoint sin depender de presets

Flags globales:
  --debug    muestra logs de debug en stderr
  --offline  fuerza contexto de red offline
  --quiet    reduce logs no esenciales
  --json     imprime salida estructurada cuando el comando lo soporta
  --dry-run  prepara el flujo sin escribir historial ni snapshots

Ejemplos:
  reina list
  reina version
  reina info bass-in-the-desert
  reina run bass-in-the-desert --dry-run
  reina net-check --offline
  reina doctor --json
  reina history bass-in-the-desert
  reina snapshot bass-in-the-desert list
  reina prune --cache
  reina ac-gtr --offline
EOF
}

function reina_cmd_resolve_preset_or_fail() {
  emulate -L zsh
  local identifier="${1:-}"
  local command_name="${2:-cli}"
  local status_code

  [[ -n "$identifier" ]] || {
    reina_fail ERR_INPUT_ARGUMENT_MISSING "falta preset" "cli" "command=$command_name"
    return $?
  }

  reina_resolve_preset_to_global "$identifier"
  status_code=$?
  if (( status_code != 0 )); then
    if (( status_code == 1 )); then
      reina_fail ERR_PRESET_NOT_FOUND "preset no encontrado: $identifier" "preset" "identifier=$identifier"
      return $?
    fi

    return "$status_code"
  fi

  reina_manifest_record_to_preset "$REINA_RESOLVED_PRESET_RECORD" || return $?
  return 0
}

function reina_version() {
  emulate -L zsh
  local version_file="${REINA_PROJECT_ROOT}/VERSION"
  local pkg_version="${REINA_VERSION:-}"

  if [[ -z "$pkg_version" && -r "$version_file" ]]; then
    IFS= read -r pkg_version < "$version_file"
  fi

  print -- "${pkg_version:-0.0.0-dev}"
}

function reina_cmd_version() {
  emulate -L zsh

  if (( $# != 0 )); then
    reina_fail ERR_CLI_USAGE "reina version no acepta argumentos posicionales" "cli" "command=version"
    return $?
  fi

  if (( REINA_JSON )); then
    print -- "{\"name\":\"reina-de-copas\",\"version\":\"$(reina_json_escape "$(reina_version)")\"}"
  else
    print -- "reina-de-copas $(reina_version)"
  fi
}

function reina_cmd_list() {
  emulate -L zsh

  if (( $# != 0 )); then
    reina_fail ERR_CLI_USAGE "reina list no acepta argumentos posicionales todavia" "cli" "command=list"
    return $?
  fi

  reina_manifest_validate || return $?
  log_debug "manifest=$REINA_MANIFEST_PATH"

  if (( REINA_JSON )); then
    reina_manifest_print_json
  else
    print -- "Preset                         Slug                           Family                         Status       Priority"
    print -- "------------------------------ ------------------------------ ------------------------------ ----------- --------"
    reina_manifest_print_table
  fi
}

function reina_cmd_info() {
  emulate -L zsh
  local identifier="${1:-}"
  local status_code

  if [[ -z "$identifier" ]]; then
    reina_fail ERR_INPUT_ARGUMENT_MISSING "uso: reina info <preset>" "cli" "command=info"
    return $?
  fi

  if (( $# > 1 )); then
    reina_fail ERR_CLI_USAGE "reina info acepta un solo preset" "cli" "command=info args=$*"
    return $?
  fi

  reina_resolve_preset_to_global "$identifier"
  status_code=$?
  if (( status_code != 0 )); then
    if (( status_code == 1 )); then
      reina_fail ERR_PRESET_NOT_FOUND "preset no encontrado: $identifier" "preset" "identifier=$identifier"
      return $?
    fi

    return "$status_code"
  fi

  reina_manifest_record_to_preset "$REINA_RESOLVED_PRESET_RECORD" || return $?
  log_debug "resolved $identifier -> $REINA_PRESET_SLUG"

  if (( REINA_JSON )); then
    reina_network_consciousness_info_json
    print -- ""
    return 0
  fi

  print -- "Preset:"
  print -- "  display_name: $REINA_PRESET_DISPLAY_NAME"
  print -- "  slug:         $REINA_PRESET_SLUG"
  print -- "  family:       $REINA_PRESET_FAMILY"
  print -- "  variant:      $REINA_PRESET_VARIANT"
  print -- "  status:       $REINA_PRESET_STATUS"
  print -- "  priority:     $REINA_PRESET_PRIORITY"
  print -- "  aliases:      $REINA_PRESET_ALIASES"
  print -- "  notes:        $REINA_PRESET_NOTES"
  print -- ""
  reina_network_consciousness_print_human
}

function reina_cmd_graph() {
  emulate -L zsh
  local identifier="${1:-}"
  local status_code

  if [[ -z "$identifier" ]]; then
    reina_fail ERR_INPUT_ARGUMENT_MISSING "uso: reina graph <preset>" "cli" "command=graph"
    return $?
  fi

  if (( $# > 1 )); then
    reina_fail ERR_CLI_USAGE "reina graph acepta un solo preset" "cli" "command=graph args=$*"
    return $?
  fi

  reina_resolve_preset_to_global "$identifier"
  status_code=$?
  if (( status_code != 0 )); then
    if (( status_code == 1 )); then
      reina_fail ERR_PRESET_NOT_FOUND "preset no encontrado: $identifier" "preset" "identifier=$identifier"
      return $?
    fi

    return "$status_code"
  fi

  reina_manifest_record_to_preset "$REINA_RESOLVED_PRESET_RECORD" || return $?
  log_debug "resolved $identifier -> $REINA_PRESET_SLUG for graph"

  if (( REINA_JSON )); then
    reina_network_consciousness_graph_print_json
    return 0
  fi

  reina_network_consciousness_graph_print_human
}

function reina_cmd_run() {
  emulate -L zsh
  local identifier="${1:-}"
  local status_code runtime_ready=0 history_recorded=0

  if [[ -z "$identifier" ]]; then
    reina_fail ERR_INPUT_ARGUMENT_MISSING "uso: reina run <preset>" "cli" "command=run"
    return $?
  fi

  if (( $# > 1 )); then
    reina_fail ERR_CLI_USAGE "reina run acepta un solo preset" "cli" "command=run args=$*"
    return $?
  fi

  reina_resolve_preset_to_global "$identifier"
  status_code=$?
  if (( status_code != 0 )); then
    if (( status_code == 1 )); then
      reina_fail ERR_PRESET_NOT_FOUND "preset no encontrado: $identifier" "preset" "identifier=$identifier"
      return $?
    fi

    return "$status_code"
  fi

  reina_manifest_record_to_preset "$REINA_RESOLVED_PRESET_RECORD" || return $?
  log_debug "resolved $identifier -> $REINA_PRESET_SLUG"

  if (( ! REINA_DRY_RUN )); then
    if ! reina_storage_ensure_runtime; then
      reina_fail ERR_STORE_INIT "no se pudo preparar el runtime" "storage" "command=run preset=$REINA_PRESET_SLUG"
      return $?
    fi
    runtime_ready=1
    reina_preset_profile_get "profile" "" >/dev/null 2>&1 || true
    reina_network_consciousness_sync_remote_profile "$REINA_PRESET_SLUG"
  fi

  reina_preset_dispatch "$runtime_ready"
  status_code=$?
  if (( status_code != 0 )); then
    return "$status_code"
  fi

  if (( ! REINA_DRY_RUN )); then
    if reina_preset_history_record "${REINA_PRESET_RESULT_STATUS:-ok}" "$status_code"; then
      history_recorded=1
    fi
    reina_network_consciousness_build_graph "$REINA_PRESET_SLUG"
  else
    reina_network_consciousness_build_graph "$REINA_PRESET_SLUG"
  fi

  if (( REINA_JSON )); then
    reina_preset_run_json "$runtime_ready" "$history_recorded"
    return 0
  fi

  reina_preset_run_print_human "$runtime_ready" "$history_recorded"
}

function reina_cmd_doctor() {
  emulate -L zsh

  if (( $# != 0 )); then
    reina_fail ERR_CLI_USAGE "reina doctor no acepta argumentos posicionales" "cli" "command=doctor args=$*"
    return $?
  fi

  reina_ops_doctor_run

  if (( REINA_JSON )); then
    reina_ops_doctor_print_json
  else
    reina_ops_doctor_print_human
  fi

  if [[ "$REINA_DOCTOR_STATUS" == "failed" ]]; then
    return 3
  fi

  return 0
}

function reina_cmd_history() {
  emulate -L zsh
  local identifier="${1:-}"

  if (( $# != 1 )); then
    reina_fail ERR_CLI_USAGE "uso: reina history <preset>" "cli" "command=history args=$*"
    return $?
  fi

  reina_cmd_resolve_preset_or_fail "$identifier" "history" || return $?

  if (( REINA_JSON )); then
    reina_ops_history_print_json "$REINA_PRESET_SLUG"
  else
    reina_ops_history_print_human "$REINA_PRESET_SLUG"
  fi
}

function reina_cmd_snapshot() {
  emulate -L zsh
  local identifier="${1:-}"
  local action="${2:-}"
  local snapshot_key="${3:-}"

  if [[ -z "$identifier" || -z "$action" ]]; then
    reina_fail ERR_CLI_USAGE "uso: reina snapshot <preset> list|restore [key]" "cli" "command=snapshot"
    return $?
  fi

  if (( $# > 3 )); then
    reina_fail ERR_CLI_USAGE "reina snapshot acepta como maximo preset, accion y key opcional" "cli" "command=snapshot args=$*"
    return $?
  fi

  reina_cmd_resolve_preset_or_fail "$identifier" "snapshot" || return $?

  case "$action" in
    list)
      if (( REINA_JSON )); then
        reina_ops_snapshot_print_list_json "$REINA_PRESET_SLUG"
      else
        reina_ops_snapshot_print_list_human "$REINA_PRESET_SLUG"
      fi
      ;;
    restore)
      reina_ops_snapshot_restore "$REINA_PRESET_SLUG" "$snapshot_key" || return $?
      if (( REINA_JSON )); then
        reina_ops_snapshot_print_restore_json "$REINA_PRESET_SLUG"
      else
        reina_ops_snapshot_print_restore_human "$REINA_PRESET_SLUG"
      fi
      ;;
    *)
      reina_fail ERR_CLI_USAGE "accion de snapshot invalida: $action" "cli" "command=snapshot action=$action"
      return $?
      ;;
  esac
}

function reina_cmd_prune() {
  emulate -L zsh
  local mode="cache"
  local arg

  for arg in "$@"; do
    case "$arg" in
      --cache)
        mode="cache"
        ;;
      --all)
        mode="all"
        ;;
      *)
        reina_fail ERR_CLI_USAGE "reina prune acepta solo --cache o --all" "cli" "command=prune args=$*"
        return $?
        ;;
    esac
  done

  if [[ "$mode" == "all" ]]; then
    reina_ops_prune_all || return $?
  else
    reina_ops_prune_cache || return $?
  fi

  if (( REINA_JSON )); then
    reina_ops_prune_print_json "$mode"
  else
    reina_ops_prune_print_human "$mode"
  fi
}

function reina_cmd_net_check() {
  emulate -L zsh
  local endpoint="${1:-${REINA_NETWORK_HEALTHCHECK_URL:-https://example.com/}}"
  local status_code=0

  if (( $# > 1 )); then
    reina_fail ERR_CLI_USAGE "reina net-check acepta cero o un endpoint" "cli" "command=net-check args=$*"
    return $?
  fi

  reina_network_check "$endpoint"
  status_code=$?

  if [[ "${REINA_RESULT_STATUS:-ok}" == "failed" ]]; then
    return "$status_code"
  fi

  if (( REINA_JSON )); then
    print -rn -- "{"
    print -rn -- "\"ok\":$(reina_error_json_bool "$([[ "$REINA_NETWORK_LAST_STATUS" == "available" || "$REINA_NETWORK_LAST_STATUS" == "offline" ]] && print 1 || print 0)"),"
    print -rn -- "\"degraded\":$(reina_error_json_bool "$([[ "$REINA_NETWORK_LAST_STATUS" == "degraded" ]] && print 1 || print 0)"),"
    print -rn -- "\"status\":\"$(reina_error_json_escape "$REINA_NETWORK_LAST_STATUS")\","
    print -rn -- "\"network\":$(reina_network_result_json),"
    print -rn -- "\"warnings\":$(reina_error_records_json warnings),"
    print -rn -- "\"degradations\":$(reina_error_records_json degradations)"
    print -- "}"

    if [[ "$REINA_NETWORK_LAST_STATUS" == "offline" ]]; then
      return 0
    fi

    return "$status_code"
  fi

  print -- "Network:"
  print -- "  status:  $REINA_NETWORK_LAST_STATUS"
  print -- "  source:  $REINA_NETWORK_LAST_SOURCE"
  print -- "  endpoint: $REINA_NETWORK_LAST_ENDPOINT"
  print -- "  client:  ${REINA_NETWORK_CLIENT:-curl}"
  print -- "  elapsed_ms: ${REINA_NETWORK_LAST_ELAPSED_MS:-0}"
  print -- "  error:   ${REINA_NETWORK_LAST_ERROR:-}"

  if [[ "$REINA_NETWORK_LAST_STATUS" == "offline" ]]; then
    return 0
  fi

  return "$status_code"
}

function reina_main() {
  emulate -L zsh

  reina_bootstrap || return $?
  reina_parse_global_flags "$@" || return $?
  reina_storage_init || return $?
  reina_network_init

  local -a args rest
  args=("${REINA_POSITIONAL_ARGS[@]}")

  local command="${args[1]:-help}"
  rest=("${args[@]:1}")

  case "$command" in
    help|-h|--help)
      if (( ${#rest[@]} > 0 )); then
        reina_fail ERR_CLI_USAGE "reina help no acepta argumentos posicionales" "cli" "command=help args=$*"
        return $?
      fi
      reina_cmd_help
      return $?
      ;;
    list)
      reina_cmd_list "${rest[@]}"
      return $?
      ;;
    version|-v|--version)
      reina_cmd_version "${rest[@]}"
      return $?
      ;;
    info)
      reina_cmd_info "${rest[@]}"
      return $?
      ;;
    graph)
      reina_cmd_graph "${rest[@]}"
      return $?
      ;;
    run)
      reina_cmd_run "${rest[@]}"
      return $?
      ;;
    doctor)
      reina_cmd_doctor "${rest[@]}"
      return $?
      ;;
    history)
      reina_cmd_history "${rest[@]}"
      return $?
      ;;
    snapshot)
      reina_cmd_snapshot "${rest[@]}"
      return $?
      ;;
    prune)
      reina_cmd_prune "${rest[@]}"
      return $?
      ;;
    net-check)
      reina_cmd_net_check "${rest[@]}"
      return $?
      ;;
    *)
      if (( ${#rest[@]} > 0 )); then
        reina_fail ERR_CLI_INVALID_COMMAND "comando invalido o argumentos extra: $command" "cli" "command=$command args=${rest[*]}"
        return $?
      fi

      reina_cmd_run "$command"
      return $?
      ;;
  esac
}

reina_main "$@"
exit $?
